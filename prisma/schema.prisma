datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

model User {
  id                         String            @id @default(uuid())
  email                      String            @unique
  passwordHash               String
  firstName                  String
  lastName                   String
  emailVerified              Boolean           @default(false)
  emailVerificationTokenHash String?
  passwordResetTokenHash     String?
  passwordResetExpires       DateTime?
  refreshTokenHash           String?           // Backward compatibility / Single session fallback
  failedLoginAttempts        Int               @default(0)
  lockUntil                  DateTime?
  lastLogin                  DateTime?
  role                       Role              @default(USER)
  yesimUserId                String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  sessions                   UserSession[]
  passwordHistories          PasswordHistory[]
  orders                     EsimOrder[]
  esimProfiles               EsimProfile[]
}

model UserSession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique // Hashed with Argon2
  deviceName      String
  browser         String
  operatingSystem String
  ipAddress       String
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
}

enum OrderStatus {
  PENDING
  PROVISIONED
  FAILED
}

model EsimProfile {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  iccid          String      @unique
  qrCodeUrl      String
  smDpAddress    String
  activationCode String
  status         String      @default("active") // active, expired, deleted
  statusString   String      @default("Released") // stores raw status_qr state: Released, Installed, Deleted, Enabled, Disabled
  dataTotalBytes BigInt      @default(0)
  dataUsedBytes  BigInt      @default(0)
  dataRemainingBytes BigInt  @default(0)
  expiresAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orders         EsimOrder[]
}

model EsimOrder {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  esimProfileId    String?
  esimProfile      EsimProfile? @relation(fields: [esimProfileId], references: [id], onDelete: SetNull)
  planId           String
  countryCode      String
  status           OrderStatus  @default(PENDING)
  amountPaid       Float
  stripeSessionId  String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model SupportedDevice {
  id        String   @id @default(uuid())
  type      String   // PHONE, TABLET, etc.
  brand     String
  model     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brand, model])
}
